# ── LinkedIn ──────────────────────────────────────────────────
LINKEDIN_EMAIL=you@email.com
LINKEDIN_PASSWORD=yourpassword
SEARCH_KEYWORDS=DevOps,SRE,Platform Engineer,Cloud Engineer
LOCATION=Remote
MAX_PAGES=5

# ── Filters ───────────────────────────────────────────────────
MAX_EXPERIENCE_YEARS=2
EXCLUDE_KEYWORDS=senior,lead,principal,staff,manager,director,vp

# ── Freshness filter (minutes) ────────────────────────────────
FRESHNESS_MINUTES=30

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8XA
TELEGRAM_CHAT_ID=81

# ── AWS S3 ────────────────────────────────────────────────────
S3_BUCKET=my-job-hunter-bucket
S3_PREFIX=jobs
AWS_REGION=us-east-1
# Leave blank when using GitHub Actions OIDC or an IAM role (recommended)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Misc ──────────────────────────────────────────────────────
RUN_ONCE=false
DEDUP_DB=seen_jobs.db
